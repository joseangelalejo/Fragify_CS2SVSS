# ============================================================
# Fragify — Variables de entorno
# Copiar como .env.local para desarrollo local
# En Vercel: añadir en Settings → Environment Variables
# ============================================================

# ── Base de datos MySQL
# En homelab (dev): apunta al contenedor MySQL por nombre de servicio
DATABASE_URL=mysql://fragify_app:PASSWORD@mysql:3306/cs2svss
# En Vercel (prod): apunta al homelab expuesto públicamente
# DATABASE_URL=mysql://fragify_app:PASSWORD@tu-dominio.com:3307/cs2svss

# ── Telegram (obtener de @BotFather y @userinfobot)
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHH
TELEGRAM_CHAT_ID=-100123456789

# ── Secrets internos (generar con: openssl rand -hex 32)
API_SECRET=
CRON_SECRET=

# ── URLs
# En dev local:
NEXT_PUBLIC_APP_URL=http://192.168.24.103:3003
API_URL=http://localhost:3003
# En Vercel prod:
# NEXT_PUBLIC_APP_URL=https://fragify.miniserver.online
# API_URL=https://fragify.miniserver.online
