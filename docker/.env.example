# ============================================================
# Fragify — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a git (está en .gitignore).
# ============================================================

# ── MySQL
MYSQL_ROOT_PASSWORD=cambia_esto_root
MYSQL_USER=fragify_app
MYSQL_PASSWORD=cambia_esto_app

# ── Telegram (obtener de @BotFather y @userinfobot)
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJ
TELEGRAM_CHAT_ID=-100123456789

# ── API interna (backend en homelab)
API_SECRET=genera_un_secret_aleatorio_aqui
# URL pública del backend (nginx → contenedor api)
API_URL=https://fragify-api.miniserver.online

# ── Frontend en Vercel
NEXT_PUBLIC_APP_URL=https://fragify.miniserver.online
# También usado por el monitor para comprobar disponibilidad

# ── Monitor
MONITOR_ENV=production            # production | staging
CHECK_INTERVAL_MS=30000           # Cada 30s: comprueba servicios
NEW_USER_CHECK_MS=60000           # Cada 60s: nuevos usuarios/reportes

# ── Backup
BACKUP_DIR=/home/dockerja/fragify/backups
MYSQL_CONTAINER=fragify_mysql
RETENTION_DAYS=30
